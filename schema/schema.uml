@startuml C4_Social_Network
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_TOP_DOWN()
LAYOUT_WITH_LEGEND()

title Social Network — System & Container Diagram

Person(user, "User", "Browses feed, creates posts, uploads media")

Container(cdn, "CDN", "Keep hot media files for traffic economy, pull model")

System_Boundary(sn, "Social Network System") {

  Container(api_gw, "API Gateway", "Nginx / Kong", "SSL termination, auth, rate limiting; routes to appropriate BFF")

  Container(mobile_bff, "Mobile BFF", "Service", "Aggregates and shapes responses for mobile clients")
  Container(web_bff,    "Web BFF",    "Service", "Aggregates and shapes responses for web clients")

  Container(media_svc,    "Media Service",    "Service", "Processes media files; stages uploads in temp bucket, promotes to main on post creation")
  Container(post_svc,     "Post Service",     "Service", "Manages posts, comments, and reactions, searching")
  Container(feed_svc,     "Feed Service",     "Service", "Listens to new_posts and relation_ops topics;\nmaintains user feed, home feed, celebrities feed (merge home&celebrities feeds)")
  Container(relation_svc, "Relation Service", "Service", "Manages follow/unfollow; publishes relation events")

  ContainerDb(post_db,     "Post DB",     "PostgreSQL+PostGIS (for spatial queries)\nRF=3, Master–Slave", "Tables: posts, comments, reactions\npost_outbox — transactional outbox for reliable Kafka publishing")
  ContainerDb(feed_db,     "Feed DB",     "Redis", "Per-user feed: last 10 own posts + last 20 followers' posts (30 entries × 4 KB)\nEstimated size: 4 KB × 30 × 10 000 000 users ≈ 1.2 TB * 3 RF = 3.6 TB")
  ContainerDb(relation_db, "Relation DB", "Neo4j\n(bitmap indexes)", "Nodes: users. Edges: follows, blocks, mutes\nrelation_outbox — transactional outbox for reliable Kafka publishing")
  Container(kafka, "Message Broker", "Apache Kafka", "Topics:\n  new_posts: post_svc publishes post IDs → feed_svc\n relation_ops: relation_svc publishes sub/unsub events → feed_svc")

  Container(cdc, "CDC Service", "Debezium / custom job", "Monitors temp_media bucket with age threshold T (skips objects newer than T);\ndeletes confirmed orphaned files from temp bucket")
}

System_Ext(blob,      "Blob Storage (main)", "S3 / NetApp — permanent media for published posts, RF is 3")
System_Ext(temp_blob, "Blob Storage (temp)", "S3 / NetApp — staging bucket for media uploaded before post creation")

' ── User → Gateway ──────────────────────────────────────────────
Rel(user, api_gw,)
Rel(user, cdn,)

' ── Gateway → BFFs ──────────────────────────────────────────────
Rel(api_gw, mobile_bff,)
Rel(api_gw, web_bff,)

' ── BFFs → Services ─────────────────────────────────────────────
Rel(mobile_bff, media_svc, )
Rel(mobile_bff, post_svc,)
Rel(mobile_bff, feed_svc,)
Rel(mobile_bff, relation_svc,)

Rel(web_bff, media_svc,)
Rel(web_bff, post_svc,)
Rel(web_bff, feed_svc,)
Rel(web_bff, relation_svc,)

' ── Media flow ──────────────────────────────────────────────────
Rel(media_svc, temp_blob,)
Rel(media_svc, blob,)
Rel(cdn, blob,)

' ── Post flow ───────────────────────────────────────────────────
Rel(post_svc, post_db,)
Rel(post_svc, media_svc,)
Rel(post_svc, kafka,)

' ── CDC flow (temp bucket only) ─────────────────────────────────
Rel(temp_blob, cdc, "Object lifecycle events (age > T)", "S3 event / polling")
Rel(cdc, temp_blob, "Delete confirmed orphaned media",  "S3 API")

' ── Relation flow ───────────────────────────────────────────────
Rel(relation_svc, relation_db,)
Rel(relation_svc, kafka,)

' ── Feed flow ───────────────────────────────────────────────────
Rel(feed_svc, kafka,)
Rel(feed_svc, feed_db,)
Rel(feed_svc, post_svc, "Read from post_svc directly if feed exhausted")

@enduml