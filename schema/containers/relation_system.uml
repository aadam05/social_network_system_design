@startuml C4_Social_Network
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Social Network — Relation System & Container Diagram

Person(user, "User", "Makes follow/unfollow operations")

Container(api_gw, "API Gateway", "Nginx", "Hides infra and proxies requests to relation service")

Container(mobile_bff, "Mobile BFF", "Service", "Aggregates and shapes responses for mobile clients")
Container(web_bff, "Web BFF", "Service", "Aggregates and shapes responses for web clients")

System_Boundary(sn, "Relation System") {
    Container(relation_svc, "Relation Service", "Service", "Manages follow/unfollow")
    ContainerDb(relation_db, "Relation DB", "Neo4j (bitmap indexes)", "Nodes: users. Edges: follows, blocks, mutes; relation_outbox — transactional outbox for reliable Kafka publishing")
}

Container(kafka, "Message Broker", "Apache Kafka", "topics: new_posts, relation_ops")

' ── User → End-To-End ──────────────────────────────────────────────
Rel(user, api_gw,)

' ── Gateway → BFFs ──────────────────────────────────────────────
Rel(api_gw, mobile_bff,)
Rel(api_gw, web_bff,)

' ── BFFs → Services ─────────────────────────────────────────────
Rel(mobile_bff, relation_svc,)
Rel(web_bff, relation_svc,)

' ── Relation flow ───────────────────────────────────────────────────
Rel(relation_svc, relation_db,)
Rel(relation_svc, kafka, "Publish events into relation_ops topic")

@enduml